NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=1

DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

CORS_ORIGINS=http://localhost:3000

JWT_SECRET=please-change-me
JWT_EXPIRES_IN=7d

DEFAULT_TIMEZONE=Asia/Dhaka

THROTTLE_TTL=60
THROTTLE_LIMIT=100

LOG_LEVEL=debug

SWAGGER_ENABLED=true
SWAGGER_PATH=docs
